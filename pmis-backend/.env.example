# Flask Configs
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=generate-a-long-secure-random-string-here

# Database Configs
# If using SQLite (default sprint behavior):
DATABASE_URL=sqlite:///pmis.db

# If switching to Postgres in Docker:
# DATABASE_URL=postgresql://pmis_user:pmis_password@localhost:5432/pmis_db

# CORS Config
ALLOWED_ORIGINS=http://localhost:5173
